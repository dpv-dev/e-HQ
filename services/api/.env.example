# ë • HQ API — environment template (committable; NO real secrets here).
# Copy values into the runtime env (Hostinger slot env vars, or a gitignored .env).

# --- Postgres (Supabase pooler, session mode, port 5432) ---
# Used by the API and by Drizzle migrations. Replace YOUR_DB_PASSWORD.
DATABASE_URL=postgresql://postgres.ywibsaorpqyzovdtjkui:YOUR_DB_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# --- Supabase (used by @supabase/server SDK + JWT verification) ---
SUPABASE_URL=https://ywibsaorpqyzovdtjkui.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx   # public key (safe to expose)
SUPABASE_SECRET_KEY=sb_secret_xxx             # SECRET — runtime env only, NEVER commit
SUPABASE_JWKS_URL=https://ywibsaorpqyzovdtjkui.supabase.co/auth/v1/.well-known/jwks.json

# Legacy (still read by the hand-rolled JWKS verifier in src/auth.ts):
SUPABASE_JWT_SECRET=

# --- Server bind ---
HOST=0.0.0.0
PORT=8787
NODE_ENV=production

# --- Mutations ---
# Required in production to enable guarded write endpoints.
WRITES_ENABLED=true
